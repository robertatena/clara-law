"use client";

import { useMemo, useState } from "react";
import { AnalysisResult } from "@/components/AnalysisResult";
import { generateLawyerEmail } from "@/lib/generateLawyerEmail";

type Result = {
  hasText: boolean;
  summary?: string;
  attentionPoints: string[];
  meta?: any;
};

type Mode = "pdf" | "text";

export default function AnalyzePage() {
  const [mode, setMode] = useState<Mode>("pdf");
  const [text, setText] = useState("");
  const [file, setFile] = useState<File | null>(null);

  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const [result, setResult] = useState<Result | null>(null);

  const canAnalyzeText = useMemo(() => text.trim().length >= 80, [text]);

  async function analyzeText() {
    setLoading(true);
    setError(null);
    setResult(null);

    try {
      const res = await fetch("/api/analyze", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ text }),
      });

      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data?.error || "Erro ao analisar texto.");

      setResult(data.result);
    } catch (e: any) {
      setError(String(e?.message || e));
    } finally {
      setLoading(false);
    }
  }

  async function analyzePdf() {
    if (!file) {
      setError("Selecione um PDF para continuar.");
      return;
    }

    setLoading(true);
    setError(null);
    setResult(null);

    try {
      const fd = new FormData();
      fd.append("file", file);

      const res = await fetch("/api/analyze-pdf", { method: "POST", body: fd });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data?.error || "Erro ao enviar PDF.");

      setResult(data.result);
    } catch (e: any) {
      setError(String(e?.message || e));
    } finally {
      setLoading(false);
    }
  }

  async function copyLawyerEmail() {
    if (!result?.attentionPoints?.length) return;
    const email = generateLawyerEmail(result.attentionPoints);
    await navigator.clipboard.writeText(email);
    alert("E-mail copiado. � s� colar e enviar.");
  }

  return (
    <main className="bg-neutral-50 min-h-screen">
      <div className="mx-auto max-w-4xl px-6 py-12">
        <div className="flex items-start justify-between gap-6">
          <div>
            <h1 className="text-3xl font-semibold tracking-tight">An�lise do contrato</h1>
            <p className="mt-2 text-neutral-600 leading-relaxed">
              A Clara organiza os pontos que merecem aten��o antes da assinatura - com linguagem clara e foco em decis�o.
            </p>
          </div>

          <div className="hidden sm:block rounded-2xl border bg-white px-4 py-3 text-sm text-neutral-600 shadow-sm">
            <div className="font-medium text-neutral-800">Dica</div>
            PDFs pesquis�veis geram an�lises mais completas. Se estiver escaneado, cole o texto.
          </div>
        </div>

        <div className="mt-8 inline-flex rounded-2xl border bg-white p-1 shadow-sm">
          <button
            onClick={() => setMode("pdf")}
            className={"rounded-xl px-4 py-2 text-sm " + (mode === "pdf" ? "bg-black text-white" : "text-neutral-700")}
          >
            Enviar PDF
          </button>
          <button
            onClick={() => setMode("text")}
            className={"rounded-xl px-4 py-2 text-sm " + (mode === "text" ? "bg-black text-white" : "text-neutral-700")}
          >
            Colar texto
          </button>
        </div>

        <div className="mt-6 rounded-2xl border bg-white p-6 shadow-sm">
          {mode === "pdf" ? (
            <div>
              <div className="text-sm font-medium text-neutral-800">PDF do contrato</div>
              <p className="mt-1 text-sm text-neutral-600">
                Envie um PDF. Se for escaneado (imagem), a Clara pode n�o ler o conte�do integral - mas ainda assim orienta os pontos essenciais.
              </p>

              <div className="mt-4 rounded-2xl border border-dashed bg-neutral-50 p-6">
                <input
                  type="file"
                  accept="application/pdf"
                  onChange={(e) => setFile(e.target.files?.[0] || null)}
                  className="block w-full text-sm"
                />
                {file && (
                  <div className="mt-3 text-sm text-neutral-700">
                    Selecionado: <span className="font-medium">{file.name}</span>
                  </div>
                )}
              </div>

              <button
                onClick={analyzePdf}
                disabled={loading || !file}
                className="mt-5 rounded-xl bg-black px-6 py-3 text-white disabled:opacity-50"
              >
                {loading ? "Lendo com aten��o..." : "Analisar PDF"}
              </button>
            </div>
          ) : (
            <div>
              <div className="text-sm font-medium text-neutral-800">Texto do contrato</div>
              <p className="mt-1 text-sm text-neutral-600">
                Cole o texto integral (ou a parte relevante). A Clara retornar� pontos de aten��o e pr�ximos passos.
              </p>

              <textarea
                value={text}
                onChange={(e) => setText(e.target.value)}
                placeholder="Cole aqui o texto do contrato..."
                className="mt-4 min-h-[180px] w-full rounded-2xl border bg-white p-4 text-sm leading-relaxed"
              />

              <div className="mt-4 flex items-center justify-between gap-4">
                <div className="text-xs text-neutral-500">
                  {canAnalyzeText ? "Pronto para analisar." : "Cole pelo menos 80 caracteres para uma an�lise significativa."}
                </div>
                <button
                  onClick={analyzeText}
                  disabled={loading || !canAnalyzeText}
                  className="rounded-xl bg-black px-6 py-3 text-white disabled:opacity-50"
                >
                  {loading ? "Lendo com aten��o..." : "Analisar texto"}
                </button>
              </div>
            </div>
          )}
        </div>

        {error && (
          <div className="mt-6 rounded-2xl border border-red-200 bg-red-50 p-4 text-red-800">
            <div className="font-semibold">Algo n�o saiu como esperado</div>
            <div className="mt-1 text-sm">{error}</div>
          </div>
        )}

        {result && (
          <>
            <AnalysisResult hasText={result.hasText} summary={result.summary} attentionPoints={result.attentionPoints} />

            <div className="mt-6 rounded-2xl border bg-white p-6 shadow-sm">
              <h2 className="text-lg font-semibold">Falar com seu advogado</h2>
              <p className="mt-2 text-neutral-600 leading-relaxed">
                Gere um e-mail objetivo com os pontos de aten��o para acelerar a revis�o jur�dica.
              </p>

              <div className="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center">
                <button onClick={copyLawyerEmail} className="rounded-xl bg-black px-6 py-3 text-white">
                  Gerar e-mail para advogado
                </button>

                <button
                  onClick={() => {
                    setResult(null);
                    setError(null);
                    setText("");
                    setFile(null);
                    setMode("pdf");
                  }}
                  className="rounded-xl border px-6 py-3"
                >
                  Nova an�lise
                </button>
              </div>
            </div>
          </>
        )}
      </div>
    </main>
  );
}

