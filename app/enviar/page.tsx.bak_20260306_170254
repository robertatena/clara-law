              <h3 style={{ margin: 0, fontSize: 18 }}>E-mail pronto</h3>
              <p style={{ marginTop: 8, color: COLORS.text, lineHeight: 1.6 }}>
                Abra com assunto e corpo preenchidos, ou copie o texto.
              </p>

              <div style={{ display: "flex", gap: 10, marginTop: 10 }}>
                <button
                  onClick={openEmail}
                  disabled={!emailDraft}
                  style={{
                    padding: "10px 14px",
                    borderRadius: 999,
                    border: "none",
                    background: emailDraft ? "#9AA0A6" : "#E6E8EC",
                    color: emailDraft ? "#fff" : "#9AA0A6",
                    fontWeight: 800,
                    cursor: emailDraft ? "pointer" : "not-allowed",
                  }}
                >
                  Abrir e-mail
                </button>

                <button
                  onClick={copyEmail}
                  disabled={!emailDraft}
                  style={{
                    padding: "10px 14px",
                    borderRadius: 999,
                    border: "1px solid #E6E8EC",
                    background: "#fff",
                    color: emailDraft ? COLORS.ink : "#9AA0A6",
                    fontWeight: 800,
                    cursor: emailDraft ? "pointer" : "not-allowed",
                  }}
                >
                  Copiar e-mail
                </button>
              </div>

              {emailDraft && (
                <div
                  style={{
                    marginTop: 12,
                    padding: 12,
                    borderRadius: 14,
                    border: "1px solid #EEF0F3",
                    background: "#FBFBFC",
                    whiteSpace: "pre-wrap",
                    fontSize: 13,
                    color: COLORS.text,
                    lineHeight: 1.5,
                  }}
                >
                  <b>Assunto:</b> {emailDraft.subject}
                  {"\n\n"}
                  {emailDraft.body}
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
