                        <div
                          style={{
                            fontSize: 12,
                            padding: "4px 10px",
                            borderRadius: 999,
                            background: f.severity === "high" ? "#FFF1F0" : f.severity === "attention" ? "#FFFBE6" : "#F6FFED",
                            border: f.severity === "high" ? "1px solid #FFCCC7" : f.severity === "attention" ? "1px solid #FFE58F" : "1px solid #B7EB8F",
