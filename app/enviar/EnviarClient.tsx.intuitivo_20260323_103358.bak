              <BlocoAcessoClara unlocked={unlocked} setUnlocked={setUnlocked} />

              {unlocked && (


              <Card title="Mensagem pronta para pedir correção" subtitle="Antes de reclamar, você pode enviar esta mensagem para pedir correção, esclarecimento ou nova versão do contrato.">
                <div style={{ display: "flex", gap: 10, flexWrap: "wrap" }}>
                  <GhostBtn onClick={openEmail} disabled={!emailDraft}>Abrir mensagem</GhostBtn>
                </div>

                {emailDraft && (
                  <div style={{ marginTop: 12, padding: 12, borderRadius: 14, border: "1px solid #EEF0F3", background: COLORS.soft2, whiteSpace: "pre-wrap", fontSize: 13, color: COLORS.text, lineHeight: 1.5 }}>
                    <b>Assunto:</b> {emailDraft.subject}
                    {"\n\n"}
                    {emailDraft.body}
                  </div>
                )}
              </Card>
              )}

              {/* FINAL: <a href="https://www.reclameaqui.com.br/" target="_blank" rel="noreferrer" style={{ color: COLORS.ink, fontWeight: 800, textDecoration: "underline" }}>Reclame Aqui</a> / Procon / gov — depois dos resultados */}              {unlocked && (

              <Card
                title="Se não resolver, use esta reclamação"
                subtitle="Se a empresa não corrigir o problema, use os links abaixo e copie o texto pronto."
              >
                <div style={{ marginBottom: 12, padding: 16, borderRadius: 16, border: "1px solid #E5E7EB", background: "#F9FAFB" }}>
                  <div style={{ fontWeight: 800, color: COLORS.ink }}>Próximos passos</div>
                  <div style={{ marginTop: 8, fontSize: 14, color: COLORS.text, lineHeight: 1.5 }}>
                    Se a empresa não corrigir o contrato, você pode usar estes canais:
                  </div>

                  <ul style={{ marginTop: 10, paddingLeft: 18, color: COLORS.text, lineHeight: 1.7, fontSize: 14 }}>
                    <li><a href="https://www.consumidor.gov.br/" target="_blank" rel="noreferrer" style={{ color: COLORS.ink, fontWeight: 800, textDecoration: "underline" }}>Consumidor.gov.br</a></li>
                    <li><a href="https://www.procon.sp.gov.br/" target="_blank" rel="noreferrer" style={{ color: COLORS.ink, fontWeight: 800, textDecoration: "underline" }}>Procon</a></li>
                    <li><a href="https://www.reclameaqui.com.br/" target="_blank" rel="noreferrer" style={{ color: COLORS.ink, fontWeight: 800, textDecoration: "underline" }}>Reclame Aqui</a></li>
                  </ul>

                  <div style={{ marginTop: 10, fontSize: 13, color: COLORS.muted, lineHeight: 1.5 }}>
                    Dica: selecione os principais pontos em “Adicionar à minha defesa” antes de copiar sua reclamação.
                  </div>
                </div>
                

                <div style={{ display: "grid", gap: 12 }}>
                  <div style={{ padding: 12, borderRadius: 14, border: "1px solid #EEF0F3", background: COLORS.soft2 }}>
                    <div style={{ display: "flex", justifyContent: "space-between", gap: 10, alignItems: "center" }}>
                      <div style={{ fontWeight: 900 }}>Reclamação pronta</div>
                      <button
                        onClick={async () => {
                          await navigator.clipboard.writeText(complaintText);
                          alert("Texto copiado!");
                        }}
                        style={{
                          padding: "10px 14px",
                          borderRadius: 999,
                          border: "none",
                          background: COLORS.ink,
                          color: "#fff",
                          fontWeight: 900,
                          cursor: "pointer",
                        }}
                      >
                        Copiar e usar
                      </button>
                    </div>

                    <textarea
                      value={complaintText}
                      readOnly
                      style={{
                        width: "100%",
                        marginTop: 10,
                        minHeight: 220,
                        padding: 12,
                        borderRadius: 12,
                        border: "1px solid " + COLORS.line,
                        fontSize: 13,
                        lineHeight: 1.5,
                        color: COLORS.text,
                        background: "#fff",
                      }}
                    />
                    <div style={{ marginTop: 8, fontSize: 12, color: COLORS.muted }}>
                      Dica: clique em “Adicionar à minha defesa” nos pontos mais importantes para deixar sua reclamação mais forte e objetiva.
                    </div>
                  </div>
                </div>
              </Card>
              )}
            </div>
          )}
        </div>
      </div>
      </div>
    );
  }


function BlocoAcessoClara({
  unlocked,
  setUnlocked,
}: {
  unlocked: boolean;
  setUnlocked: React.Dispatch<React.SetStateAction<boolean>>;
}) {
  const [mostrarPrevia, setMostrarPrevia] = useState(false);

  return (
    <div
      style={{
        marginTop: 24,
        borderRadius: 24,
        border: "1px solid #E6EAF0",
        background: "#F8FAFC",
        padding: 20,
      }}
    >
      <div
        style={{
          display: "flex",
          justifyContent: "space-between",
          gap: 16,
          alignItems: "flex-start",
          flexWrap: "wrap",
        }}
      >
        <div style={{ maxWidth: 760 }}>
          <div style={{ fontSize: 18, fontWeight: 900, color: "#0F172A" }}>
            Desbloqueie sua análise completa
          </div>
          <div style={{ marginTop: 6, fontSize: 14, color: "#475569", lineHeight: 1.6 }}>
            Receba a versão completa da análise com sugestões mais estratégicas para revisar,
            negociar ou contestar este contrato.
          </div>

          <div
            style={{
              marginTop: 14,
              display: "grid",
              gap: 8,
              fontSize: 13,
              color: "#334155",
            }}
          >
            <div>✔ Defesa completa sugerida pela Clara</div>
            <div>✔ Mensagem pronta para pedir correção</div>
            <div>✔ Texto para reclamação mais forte e objetiva</div>
            <div>✔ Próximos passos recomendados</div>
          </div>
        </div>

        <div
          style={{
            minWidth: 280,
            flex: "0 0 280px",
            borderRadius: 20,
            border: "1px solid #D8E1EA",
            background: "#fff",
            padding: 16,
          }}
        >
          <div style={{ fontSize: 12, color: "#64748B", textTransform: "uppercase", fontWeight: 800 }}>
            Acesso individual
          </div>

          <div style={{ marginTop: 8, fontSize: 28, fontWeight: 900, color: "#0F172A" }}>
            R$ 19,90
          </div>

          <div style={{ marginTop: 4, fontSize: 13, color: "#64748B", lineHeight: 1.5 }}>
            Liberação imediata da análise completa neste contrato.
          </div>

          {!unlocked ? (
            <>
              <button
                type="button"
                onClick={() => {
                  alert("Fluxo de pagamento em MVP: por enquanto, o clique libera a análise completa para teste.");
                  setUnlocked(true);
                }}
                style={{
                  marginTop: 14,
                  width: "100%",
                  padding: "13px 16px",
                  borderRadius: 999,
                  border: "none",
                  background: "#0F172A",
                  color: "#fff",
                  fontWeight: 900,
                  cursor: "pointer",
                }}
              >
                Pagar e liberar agora
              </button>

              <button
                type="button"
                onClick={() => setUnlocked(true)}
                style={{
                  marginTop: 10,
                  width: "100%",
                  padding: "12px 16px",
                  borderRadius: 999,
                  border: "1px solid #CBD5E1",
                  background: "#fff",
                  color: "#0F172A",
                  fontWeight: 800,
                  cursor: "pointer",
                }}
              >
                Já paguei
              </button>

              <button
                type="button"
                onClick={() => setMostrarPrevia((v) => !v)}
                style={{
                  marginTop: 10,
                  width: "100%",
                  padding: "11px 16px",
                  borderRadius: 999,
                  border: "none",
                  background: "transparent",
                  color: "#334155",
                  fontWeight: 800,
                  cursor: "pointer",
                }}
              >
                {mostrarPrevia ? "Ocultar prévia" : "Ver prévia do conteúdo"}
              </button>
            </>
          ) : (
            <div
              style={{
                marginTop: 14,
                borderRadius: 16,
                background: "#ECFDF3",
                border: "1px solid #BBF7D0",
                padding: 12,
                fontSize: 13,
                color: "#166534",
                fontWeight: 800,
              }}
            >
              Pagamento confirmado. Sua análise completa foi liberada abaixo.
            </div>
          )}
        </div>
      </div>

      {!unlocked && (
        <div
          style={{
            marginTop: 18,
            borderRadius: 20,
            border: "1px solid #DCE3EA",
            background: "#fff",
            overflow: "hidden",
            position: "relative",
          }}
        >
          <div
            style={{
              padding: 18,
              filter: mostrarPrevia ? "blur(0px)" : "blur(3px)",
              opacity: mostrarPrevia ? 0.92 : 0.70,
              userSelect: "none",
            }}
          >
            <div style={{ fontSize: 15, fontWeight: 900, color: "#0F172A", marginBottom: 12 }}>
              Defesa completa sugerida pela Clara
            </div>

            <div style={{ fontSize: 13, color: "#334155", lineHeight: 1.6 }}>
              Este é um espaço para consolidar sua argumentação antes de aceitar, assinar ou responder ao contrato.
            </div>

            <ul style={{ marginTop: 14, paddingLeft: 22, color: "#334155", lineHeight: 1.8, fontSize: 13 }}>
              <li>Peça revisão das cláusulas que reduzem sua possibilidade de contestação.</li>
              <li>Solicite critérios objetivos quando só uma parte puder decidir sozinha.</li>
              <li>Peça redação mais equilibrada sobre privacidade, renda e responsabilidades financeiras.</li>
              <li>Registre por escrito o que você aceita, o que precisa ajustar e o que não concorda em assumir.</li>
            </ul>

            <div
              style={{
                marginTop: 16,
                borderRadius: 14,
                background: "#F8FAFC",
                padding: 14,
                fontSize: 13,
                color: "#334155",
                lineHeight: 1.6,
              }}
            >
              <b>Modelo de pedido:</b> Solicito a revisão dos pontos que concentram poder excessivo,
              limitam minha defesa e ampliam obrigações sem equilíbrio contratual.
            </div>
          </div>

          {!mostrarPrevia && (
            <div
              style={{
                position: "absolute",
                inset: 0,
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
                padding: 24,
                textAlign: "center",
                background: "linear-gradient(to bottom, rgba(255,255,255,0.12), rgba(255,255,255,0.84))",
              }}
            >
              <div>
                <div style={{ fontSize: 28, marginBottom: 8 }}>🔒</div>
                <div style={{ fontWeight: 900, color: "#0F172A", fontSize: 16 }}>
                  Conteúdo premium bloqueado
                </div>
                <div style={{ marginTop: 6, fontSize: 13, color: "#475569", lineHeight: 1.5, maxWidth: 460 }}>
                  Libere a análise completa para acessar a defesa sugerida, a mensagem pronta e os próximos passos.
                </div>
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  );
}













