import { NextResponse } from "next/server";
import pdf from "pdf-parse";
import mammoth from "mammoth";

export const runtime = "nodejs";

function extFromName(name: string) {
  const m = name.toLowerCase().match(/\.([a-z0-9]+)$/);
  return m ? m[1] : "";
}

export async function POST(req: Request) {
  const form = await req.formData();
  const file = form.get("file");

  if (!(file instanceof File)) {
    return NextResponse.json({ error: "missing_file" }, { status: 400 });
  }

  const name = file.name || "arquivo";
  const ext = extFromName(name);

  const ab = await file.arrayBuffer();
  const buf = Buffer.from(ab);

  try {
    // TXT
    if (ext === "txt" || file.type.startsWith("text/")) {
      const text = buf.toString("utf8");
      return NextResponse.json({ ok: true, kind: "txt", name, text });
    }

    // PDF
    if (ext === "pdf" || file.type === "application/pdf") {
      const parsed = await pdf(buf);
      const text = (parsed.text || "").trim();
      return NextResponse.json({ ok: true, kind: "pdf", name, text });
    }

    // DOCX
    if (ext === "docx" || file.type === "application/vnd.openxmlformats-officedocument.wordprocessingml.document") {
      const out = await mammoth.extractRawText({ buffer: buf });
      const text = (out.value || "").trim();
      return NextResponse.json({ ok: true, kind: "docx", name, text });
    }

    // Outros formatos: aceitamos upload mas ainda não extraímos
    return NextResponse.json({
      ok: true,
      kind: "other",
      name,
      text: "",
      note: "Arquivo recebido. Extração automática disponível hoje para PDF, DOCX e TXT. Para outros formatos, cole o texto ou envie PDF."
    });
  } catch (e: any) {
    return NextResponse.json({ error: "extract_failed", message: e?.message || "Falha ao extrair" }, { status: 500 });
  }
}
