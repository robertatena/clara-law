import { NextResponse } from "next/server";
import pdf from "pdf-parse";

export const runtime = "nodejs";

function buildAttentionPoints(text: string): string[] {
  const t = text.toLowerCase();
  const points: string[] = [];

  points.push("Prazo de vigência e se existe renovação automática (e como cancelar).");
  points.push("Multa e condições de rescisão (aviso prévio, janelas e valores).");
  points.push("Critérios de reajuste (índice, periodicidade e limites).");
  points.push("Responsabilidades das partes durante e após o contrato (entregas, suporte, devoluções).");

  if (t.includes("fidelidade") || t.includes("permanência")) points.push("Cláusulas de fidelidade/permanência: duração e multa proporcional.");
  if (t.includes("foro") || t.includes("comarca")) points.push("Foro eleito: verifique impacto prático (custo e deslocamento).");
  if (t.includes("confidencial") || t.includes("sigilo") || t.includes("nda")) points.push("Confidencialidade: duração, penalidades e exceções.");
  if (t.includes("lgpd") || t.includes("dados pessoais") || t.includes("controlador") || t.includes("operador")) points.push("LGPD: finalidade, base legal, retenção, compartilhamento e segurança.");
  if (t.includes("juros") || t.includes("mora") || t.includes("inadimplemento")) points.push("Inadimplemento: juros/mora, correção e consequências do atraso.");

  return Array.from(new Set(points)).slice(0, 12);
}

function fallbackPoints(): string[] {
  return [
    "Prazo de vigência e se existe renovação automática (e como cancelar).",
    "Multa e condições de rescisão (aviso prévio, janelas e valores).",
    "Critérios de reajuste (índice, periodicidade e limites).",
    "Responsabilidades e garantias (inclusive obrigações pós-encerramento).",
    "Se houver dados pessoais, valide finalidade, base legal, retenção e compartilhamento (LGPD).",
  ];
}

export async function POST(req: Request) {
  try {
    const form = await req.formData();
    const file = form.get("file");

    if (!(file instanceof File)) {
      return NextResponse.json({ error: "Arquivo não enviado (campo 'file')." }, { status: 400 });
    }

    const MAX = 12 * 1024 * 1024;
    if (file.size > MAX) {
      return NextResponse.json({ error: "Arquivo muito grande (máx. 12MB)." }, { status: 413 });
    }

    const ab = await file.arrayBuffer();
    const buffer = Buffer.from(ab);

    let extracted = "";
    try {
      const parsed = await pdf(buffer);
      extracted = (parsed?.text || "").trim();
    } catch {
      extracted = "";
    }

    if (extracted.length >= 80) {
      const attentionPoints = buildAttentionPoints(extracted);
      return NextResponse.json({
        ok: true,
        result: {
          hasText: true,
          summary:
            "Leitura concluída a partir do PDF. Abaixo estão os pontos que mais merecem atenção antes da assinatura.",
          attentionPoints,
          meta: { name: file.name, size: file.size, type: file.type },
        },
      });
    }

    return NextResponse.json({
      ok: true,
      result: {
        hasText: false,
        summary:
          "Este PDF parece estar em formato de imagem ou sem texto pesquisável. Para uma análise completa, envie uma versão pesquisável (OCR) ou cole o texto. Ainda assim, a Clara organizou os pontos essenciais para você revisar antes de assinar.",
        attentionPoints: fallbackPoints(),
        meta: { name: file.name, size: file.size, type: file.type },
      },
    });
  } catch (e: any) {
    return NextResponse.json({ error: "Falha ao processar PDF.", details: String(e?.message || e) }, { status: 500 });
  }
}
