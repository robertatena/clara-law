"use client";

import React from "react";

type RiskLevel = "baixo" | "medio" | "alto";
type PartyRole = "contratante" | "contratado";

type Props = {
  title: string;
  level: RiskLevel;
  summary: string;
  clauseTitle?: string;
  clauseExcerpt?: string;
  whyItMatters?: string[];
  whatToDo?: string[];
  role?: PartyRole;
  confidence?: "alta" | "media" | "baixa";
};

const levelLabel: Record<RiskLevel, string> = {
  baixo: "Baixo",
  medio: "Médio",
  alto: "Alto",
};

const levelStyles: Record<RiskLevel, string> = {
  baixo: "bg-emerald-50 text-emerald-700 ring-emerald-200",
  medio: "bg-amber-50 text-amber-700 ring-amber-200",
  alto: "bg-rose-50 text-rose-700 ring-rose-200",
};

export default function RiskCard({
  title,
  level,
  summary,
  clauseTitle,
  clauseExcerpt,
  whyItMatters = [],
  whatToDo = [],
  role,
  confidence = "media",
}: Props) {
  return (
    <section className="rounded-2xl border border-neutral-200 bg-white shadow-sm">
      <header className="flex items-start justify-between gap-4 p-5">
        <div className="min-w-0">
          <h3 className="text-base font-semibold text-neutral-900">{title}</h3>
          <p className="mt-1 text-sm text-neutral-600">{summary}</p>

          <div className="mt-3 flex flex-wrap items-center gap-2">
            <span className={`inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ring-1 ${levelStyles[level]}`}>
              {levelLabel[level]}
            </span>

            {role && (
              <span className="inline-flex items-center rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-700 ring-1 ring-neutral-200">
                Perfil: {role === "contratante" ? "Contratante" : "Contratado"}
              </span>
            )}

            <span className="inline-flex items-center rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-700 ring-1 ring-neutral-200">
              Confiança: {confidence}
            </span>
          </div>
        </div>
      </header>

      {(clauseTitle || clauseExcerpt) && (
        <div className="px-5">
          <div className="rounded-xl bg-neutral-50 p-4 ring-1 ring-neutral-200">
            <p className="text-xs font-semibold uppercase tracking-wide text-neutral-700">
              Trecho do contrato
            </p>
            {clauseTitle && (
              <p className="mt-1 text-sm font-semibold text-neutral-900">{clauseTitle}</p>
            )}
            {clauseExcerpt && (
              <pre className="mt-2 whitespace-pre-wrap text-sm leading-6 text-neutral-700">
                {clauseExcerpt}
              </pre>
            )}
          </div>
        </div>
      )}

      <div className="grid gap-4 p-5 md:grid-cols-2">
        {whyItMatters.length > 0 && (
          <div className="rounded-xl border border-neutral-200 p-4">
            <p className="text-sm font-semibold text-neutral-900">Por que isso importa</p>
            <ul className="mt-2 space-y-2 text-sm text-neutral-700">
              {whyItMatters.map((x, i) => (
                <li key={i} className="flex gap-2">
                  <span className="mt-2 h-1.5 w-1.5 rounded-full bg-neutral-400" />
                  <span className="flex-1">{x}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {whatToDo.length > 0 && (
          <div className="rounded-xl border border-neutral-200 p-4">
            <p className="text-sm font-semibold text-neutral-900">O que você pode pedir</p>
            <ul className="mt-2 space-y-2 text-sm text-neutral-700">
              {whatToDo.map((x, i) => (
                <li key={i} className="flex gap-2">
                  <span className="mt-2 h-1.5 w-1.5 rounded-full bg-neutral-400" />
                  <span className="flex-1">{x}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>
  );
}